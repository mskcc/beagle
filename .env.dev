# ==============================================================================
# BEAGLE INFRASTRUCTURE SETTINGS (Used by Makefile & Compose)
# ==============================================================================
BEAGLE_DEPLOYMENT=dev
BEAGLE_VERSION=dev
BEAGLE_PORT=5007

# Host Paths (Using ${PWD} ensures Podman/Docker finds absolute paths)
BEAGLE_POSTGRES_PATH=${PWD}/infra/data/postgres
BEAGLE_LOGS_PATH=${PWD}/infra/data/logs
BEAGLE_SERVER_PATH=${PWD}/infra/data/static
BEAGLE_CELERY_PATH=${PWD}/infra/data/celery
BEAGLE_RABITMQ_PATH=${PWD}/infra/data/rabbitmq

# Temp/System Paths for Dev
BEAGLE_PGBOUNCER_PATH=${PWD}/infra/data/beagle_dev_pgbouncer
BEAGLE_LOGROTATE_PATH=${PWD}/infra/data/beagle_dev_logrotate
BEAGLE_DB_BACKUP_PATH=${PWD}/infra/data/beagle_dev_backup

# ==============================================================================
# DATABASE SETTINGS (Postgres)
# ==============================================================================
POSTGRES_DB=beagle
POSTGRES_USER=beagle
POSTGRES_PASSWORD=beagle
POSTGRES_HOST_PORT=5433

BEAGLE_DB_NAME=beagle
BEAGLE_DB_USERNAME=beagle
BEAGLE_DB_PASSWORD=beagle
BEAGLE_DB_URL=beagle_postgres
BEAGLE_DB_PORT=5432

# ==============================================================================
# BROKER SETTINGS (RabbitMQ)
# ==============================================================================
BEAGLE_RABBITMQ_URL=beagle_rabbitmq
BEAGLE_RABBITMQ_PORT=5672
BEAGLE_RABBITMQ_USERNAME=BEAGLE
BEAGLE_RABBITMQ_PASSWORD=beagle
BEAGLE_RABBITMQ_MANAGEMENT_PORT=15672

CELERY_BROKER_URL=amqp://${BEAGLE_RABBITMQ_USERNAME}:${BEAGLE_RABBITMQ_PASSWORD}@${BEAGLE_RABBITMQ_URL}:${BEAGLE_RABBITMQ_PORT}//

# ==============================================================================
# CELERY QUEUE CONFIGURATION
# ==============================================================================
BEAGLE_CELERY_EVENT_QUEUE_PREFIX=beagle.dev
BEAGLE_DEFAULT_QUEUE=beagle.dev.default.queue
BEAGLE_RUNNER_QUEUE=beagle.dev.runner.queue
BEAGLE_JOB_SCHEDULER_QUEUE=beagle.dev.job_scheduler.queue
BEAGLE_CHECK_STATUS_QUEUE=beagle.dev.check_status_queue
BEAGLE_PROCESS_TRIGGER_QUEUE=beagle.dev.process_trigger_queue

# ==============================================================================
# DJANGO APP SETTINGS
# ==============================================================================
DJANGO_SETTINGS_MODULE=beagle.settings
BEAGLE_PATH=/app/src
BEAGLE_URL=http://localhost:${BEAGLE_PORT}
